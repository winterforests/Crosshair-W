{
  "name": "crosshair-w",
  "version": "1.0.0",
  "description": "CrosshairW — free crosshair overlay",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,app -c cyan,blue \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "icons": "node scripts/make-icon.mjs",
    "dist": "npm run build && electron-builder --win",
    "dist:desktop": "npm run build && electron-builder --win --config.directories.output=%USERPROFILE%\\\\Desktop\\\\CrosshairW-release"
  },
  "author": "winter",
  "license": "MIT",
  "build": {
    "appId": "com.crosshairw.app",
    "productName": "CrosshairW",
    "copyright": "Copyright © winter",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "public/logo.png",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/koffi/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CrosshairW",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "CrosshairW-${version}-setup.exe"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "koffi": "^2.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
